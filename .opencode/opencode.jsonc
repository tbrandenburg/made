{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true,
      "timeout": 60000
    },
    "sequential_thinking": {
      "type": "local",
      "command": ["npx", "-y","@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true,
      "timeout": 60000
    },
    "playwright": {
      "type": "local",
      "command": ["npx","@playwright/mcp@latest"],
      "enabled": true,
      "timeout": 60000
    }
  },
  "permission": {
    "read": "allow",
    "write": "allow",
    "edit": "allow",
    "bash": "allow",
    "skill": "allow",
    "question": "deny",
    "doom_loop": "deny",
    "external_directory": {
      "*": "deny",
      "/tmp/*.md": "allow",
      "/tmp/opencode/**": "allow",
      "~/.local/share/opencode/tool-output/**": "allow"
    },
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "patch": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "webfetch": "allow"
  }
}
